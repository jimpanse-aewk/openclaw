# openclaw secrets.env — example
#
# Real file on the host: /home/clown/.config/openclaw/secrets.env (mode 0600)
# Loaded by openclaw-gateway.service via drop-in:
#   [Service]
#   EnvironmentFile=%h/.config/openclaw/secrets.env
#
# Fill the real values on the host only. Never commit a populated copy.

# Anthropic API key — used by the gateway to reach Claude.
ANTHROPIC_API_KEY=

# Telegram bot token for @Clown_ha_bot (id 8792388733).
# Rotate via BotFather (/revoke → /newtoken) if compromised.
TELEGRAM_BOT_TOKEN=

# Operator's Telegram numeric chat_id (used for DM pairing / default routing).
TELEGRAM_CHAT_ID=

# Long-lived Home Assistant access token (profile → Create Token).
# Consumed by socha on ELK; openclaw only needs it for direct HA REST calls.
HA_TOKEN=

# HA base URL, reachable from openclaw on the LAN.
HA_URL=http://192.168.86.15:8123
